{
  "hooks": {
    "SessionStart": [
      {
        "type": "command",
        "command": "./scripts/detect-research.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\detect-research.ps1",
        "timeout": 10
      }
    ],
    "Stop": [
      {
        "type": "command",
        "command": "./scripts/on-ia-complete.sh",
        "windows": "powershell -ExecutionPolicy Bypass -File scripts\\on-ia-complete.ps1",
        "timeout": 10
      }
    ]
  }
}
